# Application
NODE_ENV=development
PORT=3000
APP_NAME=Advanced Events

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/advanced_events
# Session
SESSION_SECRET=replace_with_random_secret
SESSION_MAX_AGE=86400000

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Advanced Events <noreply@advancedevents.co.za>

# Admin Seed
ADMIN_EMAIL=admin@advancedevents.co.za
ADMIN_PASSWORD=Admin@123
