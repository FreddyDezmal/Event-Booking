<!-- views/errors/500.ejs -->
<div class="error-page">
  <div class="container">
    <div class="error-page__content">
      <div class="error-page__code">500</div>
      <h1>Server Error</h1>
      <p><%= message || 'Something went wrong on our end. Please try again shortly.' %></p>
      <div class="error-page__actions">
        <a href="/" class="btn btn--primary">Go Home</a>
        <a href="/contact" class="btn btn--outline">Report Issue</a>
      </div>
    </div>
  </div>
</div>
