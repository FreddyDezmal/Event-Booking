<!-- views/events/detail.ejs -->
<div class="event-detail">
  <!-- Hero Banner -->
  <div class="event-detail__banner">
    <img src="<%= event.image || '/images/default-event.jpg' %>" alt="<%= event.title %>" class="event-detail__banner-img" />
    <div class="event-detail__banner-overlay">
      <div class="container">
        <span class="event-card__category"><%= event.category %></span>
        <h1 class="event-detail__title"><%= event.title %></h1>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="event-detail__grid">
      <!-- Main Info -->
      <div class="event-detail__main">
        <div class="event-detail__meta-bar">
          <div class="event-detail__meta-item">
            <span class="event-detail__meta-icon">📅</span>
            <div>
              <strong><%= new Date(event.date).toLocaleDateString('en-ZA', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %></strong>
              <small><%= new Date(event.date).toLocaleTimeString('en-ZA', { hour:'2-digit', minute:'2-digit' }) %></small>
            </div>
          </div>
          <div class="event-detail__meta-item">
            <span class="event-detail__meta-icon">📍</span>
            <div>
              <strong><%= event.venue.name %></strong>
              <small><%= event.venue.address %>, <%= event.venue.city %></small>
            </div>
          </div>
          <div class="event-detail__meta-item">
            <span class="event-detail__meta-icon">🎟</span>
            <div>
              <strong><%= event.ticketsRemaining %> tickets remaining</strong>
              <small>of <%= event.ticketCapacity %> total</small>
            </div>
          </div>
        </div>

        <!-- Capacity Bar -->
        <div class="capacity-bar">
          <div class="capacity-bar__label">
            <span>Availability</span>
            <span><%= Math.round(((event.ticketCapacity - event.ticketsRemaining) / event.ticketCapacity) * 100) %>% booked</span>
          </div>
          <div class="capacity-bar__track">
            <div class="capacity-bar__fill" style="width: <%= Math.round(((event.ticketCapacity - event.ticketsRemaining) / event.ticketCapacity) * 100) %>%"></div>
          </div>
        </div>

        <div class="event-detail__description">
          <h2>About This Event</h2>
          <p><%= event.description %></p>
        </div>

        <% if (event.tags && event.tags.length) { %>
          <div class="event-detail__tags">
            <% event.tags.forEach(tag => { %>
              <span class="tag">#<%= tag %></span>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Booking Sidebar -->
      <div class="event-detail__sidebar">
        <div class="booking-card">
          <div class="booking-card__price">
            <% if (event.ticketPrice === 0) { %>
              <span class="booking-card__price-amount">Free</span>
            <% } else { %>
              <span class="booking-card__price-currency">R</span>
              <span class="booking-card__price-amount"><%= event.ticketPrice.toLocaleString('en-ZA') %></span>
              <span class="booking-card__price-per">per ticket</span>
            <% } %>
          </div>

          <% if (event.status === 'cancelled') { %>
            <div class="alert alert--error">This event has been cancelled.</div>
          <% } else if (event.ticketsRemaining === 0) { %>
            <div class="alert alert--warning">This event is sold out.</div>
            <button class="btn btn--primary btn--full" disabled>Sold Out</button>
          <% } else if (!user) { %>
            <a href="/auth/login" class="btn btn--primary btn--full">Sign In to Book</a>
            <p class="booking-card__note">New here? <a href="/auth/register">Create an account</a> — it's free.</p>
          <% } else { %>
            <a href="/bookings/new/<%= event._id %>" class="btn btn--primary btn--full btn--lg">
              Book Tickets →
            </a>
            <p class="booking-card__note">Secure checkout · Instant confirmation</p>
          <% } %>

          <div class="booking-card__details">
            <div class="booking-card__detail">
              <span>📅 Date</span>
              <span><%= new Date(event.date).toLocaleDateString('en-ZA') %></span>
            </div>
            <div class="booking-card__detail">
              <span>📍 Venue</span>
              <span><%= event.venue.city %></span>
            </div>
            <div class="booking-card__detail">
              <span>🎟 Remaining</span>
              <span class="<%= event.ticketsRemaining <= 10 ? 'text--warning' : '' %>">
                <%= event.ticketsRemaining %> tickets
              </span>
            </div>
          </div>
        </div>

        <!-- Share -->
        <div class="share-card">
          <h4>Share This Event</h4>
          <div class="share-card__btns">
            <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!')" class="btn btn--outline btn--sm">📋 Copy Link</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Events -->
    <% if (related && related.length) { %>
      <div class="related-events">
        <h2>More <%= event.category %> Events</h2>
        <div class="events-grid">
          <% related.forEach(rel => { %>
            <%- include('../partials/event-card', { event: rel }) %>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</div>
