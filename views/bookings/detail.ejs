<!-- views/bookings/detail.ejs -->
<div class="page-header">
  <div class="container">
    <a href="/dashboard" class="page-header__back">← Back to Dashboard</a>
    <h1 class="page-header__title">Booking Details</h1>
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    <div class="ticket-card">
      <div class="ticket-card__top">
        <div class="ticket-card__event-info">
          <span class="event-card__category"><%= booking.event?.category || 'Event' %></span>
          <h2><%= booking.event?.title || 'Event Deleted' %></h2>
          <% if (booking.event) { %>
            <p>📅 <%= new Date(booking.event.date).toLocaleDateString('en-ZA', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %></p>
            <p>📍 <%= booking.event.venue?.name %>, <%= booking.event.venue?.city %></p>
          <% } %>
          <p style="margin-top:12px;">
            <span class="status-badge status-badge--<%= booking.status %>"><%= booking.status %></span>
          </p>
        </div>
        <% if (booking.qrCode && booking.status === 'confirmed') { %>
          <div class="ticket-card__qr">
            <img src="<%= booking.qrCode %>" alt="QR Code" class="ticket-card__qr-img" />
            <small>Show at entry</small>
          </div>
        <% } %>
      </div>
      <div class="ticket-card__divider">
        <div class="ticket-card__hole ticket-card__hole--left"></div>
        <div class="ticket-card__perforation"></div>
        <div class="ticket-card__hole ticket-card__hole--right"></div>
      </div>
      <div class="ticket-card__bottom">
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Booking Ref</span>
          <span class="ticket-card__detail-value ticket-card__detail-value--ref"><%= booking.bookingRef %></span>
        </div>
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Attendee</span>
          <span class="ticket-card__detail-value"><%= booking.attendeeName %></span>
        </div>
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Tickets</span>
          <span class="ticket-card__detail-value"><%= booking.quantity %></span>
        </div>
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Unit Price</span>
          <span class="ticket-card__detail-value">R <%= booking.unitPrice?.toLocaleString('en-ZA') %></span>
        </div>
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Total Paid</span>
          <span class="ticket-card__detail-value">R <%= booking.totalPrice?.toLocaleString('en-ZA') %></span>
        </div>
        <div class="ticket-card__detail">
          <span class="ticket-card__detail-label">Booked On</span>
          <span class="ticket-card__detail-value"><%= new Date(booking.createdAt).toLocaleDateString('en-ZA') %></span>
        </div>
      </div>
    </div>

    <div class="confirmation-actions">
      <button onclick="window.print()" class="btn btn--outline">🖨 Print</button>
      <% if (booking.event && booking.status === 'confirmed') { %>
        <a href="/events/<%= booking.event.slug %>" class="btn btn--outline">View Event</a>
      <% } %>
      <a href="/dashboard" class="btn btn--primary">Back to Dashboard</a>
      <% if (booking.status === 'confirmed') { %>
        <form action="/bookings/<%= booking._id %>/cancel" method="POST"
              onsubmit="return confirm('Are you sure you want to cancel this booking?')">
          <button class="btn btn--danger">Cancel Booking</button>
        </form>
      <% } %>
    </div>
  </div>
</section>
