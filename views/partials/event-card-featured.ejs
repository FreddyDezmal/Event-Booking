<!-- views/partials/event-card-featured.ejs -->
<article class="event-card-featured">
  <div class="event-card-featured__img-wrap">
    <img src="<%= event.image || '/images/default-event.jpg' %>" alt="<%= event.title %>" class="event-card-featured__img" loading="lazy" />
    <div class="event-card-featured__overlay"></div>
    <span class="event-card-featured__category"><%= event.category %></span>
  </div>
  <div class="event-card-featured__content">
    <div class="event-card-featured__date">
      <span class="event-card-featured__day"><%= new Date(event.date).getDate() %></span>
      <span class="event-card-featured__month"><%= new Date(event.date).toLocaleString('en-ZA', { month: 'short' }).toUpperCase() %></span>
    </div>
    <h3 class="event-card-featured__title"><%= event.title %></h3>
    <p class="event-card-featured__venue">📍 <%= event.venue?.name %>, <%= event.venue?.city %></p>
    <div class="event-card-featured__footer">
      <span class="event-card-featured__price">
        <% if (event.ticketPrice === 0) { %>Free<% } else { %>R <%= event.ticketPrice.toLocaleString('en-ZA') %><% } %>
      </span>
      <a href="/events/<%= event.slug %>" class="btn btn--primary btn--sm">View Event</a>
    </div>
  </div>
</article>
