<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Advanced Events</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="auth-body">
  <div class="auth-layout">
    <div class="auth-layout__panel">
      <a href="/" class="auth-layout__logo">
        <span class="nav__logo-mark">AE</span>
        <span>Advanced Events</span>
      </a>
      <div class="auth-layout__tagline">
        <h2>South Africa's Premier Event Platform</h2>
        <p>Discover, book, and experience unforgettable events.</p>
        <div class="auth-layout__dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>
    <div class="auth-layout__form">
      <% if (error && error.length) { %>
        <div class="alert alert--error"><%= error[0] %></div>
      <% } %>
      <% if (success && success.length) { %>
        <div class="alert alert--success"><%= success[0] %></div>
      <% } %>
      <%- body %>
    </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
